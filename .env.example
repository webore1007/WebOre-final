# Copy this file to .env for local development with `netlify dev`
# (netlify dev loads it automatically). In production, set these under
# Netlify → Site configuration → Environment variables instead — never
# commit a real .env file.

# Used to sign/verify login JWTs. Set this to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# --- Social login (optional) ---
# Create these in Google Cloud Console (OAuth consent screen + OAuth client
# ID, type "Web application", with your site's URL under Authorized
# JavaScript origins).
GOOGLE_CLIENT_ID=

# Facebook login only needs the App ID on the frontend (js/config.js), but
# it's also read here as a fallback if Admin -> Settings hasn't been used
# to set it yet.
FACEBOOK_APP_ID=

# Netlify Blobs (the database) and Netlify Functions themselves need no
# extra configuration/credentials — Netlify provides those automatically
# both when deployed and when running `netlify dev` locally.
